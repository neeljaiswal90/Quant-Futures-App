{
  "name": "quant-futures-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check:python": "node scripts/check-python-syntax.mjs",
    "data:01a:l1-trade": "python -m services.market_data_sidecar.app",
    "data:05a:retention": "python -m services.market_data_sidecar.retention_app",
    "data:06a:session-warmup": "python -m services.market_data_sidecar.session_warmup_app",
    "data:07a:gap-report": "python -m services.market_data_sidecar.gap_report_app",
    "format:journal": "tsx apps/strategy_runtime/src/operator/formatter.ts",
    "infra:01:evaluate": "tsx scripts/infra/evaluate-infra-01-probe.ts",
    "infra:analyze-databento-parity": "tsx scripts/infra/analyze-databento-overlap-parity.ts",
    "infra:analyze-timestamp-order": "tsx scripts/infra/analyze-rithmic-timestamp-order.ts",
    "infra:audit-rithmic-mbp10": "tsx scripts/infra/audit-rithmic-mbp10-extraction.ts",
    "journal:query": "tsx scripts/journal/journal-query.ts",
    "lint": "npm run lint:forbidden-imports",
    "lint:forbidden-imports": "node scripts/check-forbidden-imports.mjs",
    "obs:04:l1-latency": "tsx apps/strategy_runtime/src/operator/l1-trade-latency-dashboard.ts",
    "rel:00a": "tsx scripts/rel/rel-00a-offline-readiness.ts",
    "test": "vitest run",
    "tui": "tsx apps/strategy_runtime/src/operator/tui.ts",
    "tui:fixture": "tsx apps/strategy_runtime/src/operator/tui.ts --fixture obs00"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}

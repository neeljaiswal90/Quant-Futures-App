{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "rootDir": ".",
    "types": ["node"],
    "jsx": "react-jsx"
  },
  "include": [
    "apps/operator_console/server/src/**/*.ts",
    "apps/operator_console/server/tests/**/*.ts",
    "apps/operator_console/web/src/**/*.ts",
    "apps/operator_console/web/src/**/*.tsx",
    "apps/operator_console/web/tests/**/*.ts",
    "apps/operator_console/web/tests/**/*.tsx",
    "apps/strategy_runtime/src/**/*.ts",
    "apps/strategy_runtime/tests/**/*.ts",
    "scripts/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": [
    "legacy_seed/**",
    "legacy_reference/**",
    "node_modules/**",
    "dist/**",
    "build/**",
    "coverage/**"
  ]
}
